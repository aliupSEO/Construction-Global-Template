    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.8",
    "firebase-admin": "^13.8.0"
  },
  "scripts": {
    "start": "npm run kill-api && npm run dev:full",
    "dev": "vite",
    "dev:api": "node scripts/dev-api-server.mjs",
    "dev:full": "concurrently \"node scripts/dev-api-server.mjs\" \"vite\" --names \"api,vite\" --prefix-colors \"cyan,green\" --kill-others-on-fail",
    "kill-api": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}

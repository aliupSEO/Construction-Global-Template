rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }
    function getRole() {
      return request.auth.token.role;
    }
    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }
    function isVorarbeiter() {
      return isAuthenticated() && (getRole() == 'vorarbeiter' || getRole() == 'admin');
    }
    function isMitarbeiter() {
      return isAuthenticated() && getRole() != null;
    }
    function isOwnLeaveRequest() {
      return request.auth.uid == resource.data.employeeId;
    }

    // Soft-delete fields that only admins may write
    // (defined inline in each rule below)

    // ─── Default Deny All ───────────────────────────────────
    match /apps/{appId}/{document=**} {
      allow read, write: if false;
    }

    // ─── EMPLOYEES ──────────────────────────────────────────
    match /apps/{appId}/employees/{docId} {
      allow read: if isVorarbeiter();
      allow create, delete: if isAdmin();
      // Admin can update anything; vorarbeiter cannot touch soft-delete fields
      allow update: if isAdmin()
        || (isVorarbeiter() && !request.resource.data.keys().hasAny(['isDeleted', 'expireAt', 'deletedBy', 'deletedAt', 'deletedByName']));
    }

    // ─── MANAGERS ───────────────────────────────────────────
    match /apps/{appId}/managers/{docId} {
      allow read: if isVorarbeiter();
      allow create, update, delete: if isAdmin();
    }

    // ─── DAILY REPORTS ──────────────────────────────────────
    match /apps/{appId}/daily_reports/{docId} {
      allow read: if isMitarbeiter();
      allow create: if isVorarbeiter();
      allow delete: if isAdmin();
      // Admins can update anything; vorarbeiter can update but cannot write trash fields
      allow update: if isAdmin()
        || (isVorarbeiter() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isDeleted', 'expireAt', 'deletedBy', 'deletedAt', 'deletedByName']));
    }

    // ─── WEEKLY REPORTS ─────────────────────────────────────
    match /apps/{appId}/weekly_reports/{docId} {
      allow read: if isMitarbeiter();
      allow create: if isVorarbeiter();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isVorarbeiter() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isDeleted', 'expireAt', 'deletedBy', 'deletedAt', 'deletedByName']));
    }

    // ─── BAUSTELLEN (SITES) ─────────────────────────────────
    match /apps/{appId}/baustellen/{docId} {
      allow read: if isMitarbeiter();
      allow create: if isVorarbeiter();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (isVorarbeiter() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isDeleted', 'expireAt', 'deletedBy', 'deletedAt', 'deletedByName']));
    }

    // ─── CLIENTS ────────────────────────────────────────────
    match /apps/{appId}/clients/{docId} {
      allow read: if isVorarbeiter();
      allow create, update, delete: if isAdmin();
    }

    // ─── LEAVE REQUESTS ─────────────────────────────────────
    match /apps/{appId}/leave_requests/{docId} {
      allow read: if isMitarbeiter() && (isVorarbeiter() || isOwnLeaveRequest());
      allow create: if isMitarbeiter() && request.auth.uid == request.resource.data.employeeId;
      allow update: if isVorarbeiter();
      allow delete: if isAdmin();
    }

    // ─── METADATA / SETTINGS ────────────────────────────────
    match /apps/{appId}/metadata/{docId} {
      allow read: if isMitarbeiter();
      allow write: if isAdmin();
    }

    // ─── SYSTEM LOGS ────────────────────────────────────────
    match /apps/{appId}/system_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isMitarbeiter();
      allow update, delete: if false; // Immutable
    }

    // ─── ACTIONS / TASKS ────────────────────────────────────
    match /apps/{appId}/actions/{docId} {
      allow read, write: if isVorarbeiter();
    }

    // ─── SITE ACTIVITIES ────────────────────────────────────
    match /apps/{appId}/site_activities/{docId} {
      allow read: if isMitarbeiter();
      allow create, update: if isVorarbeiter();
      allow delete: if isAdmin();
    }

    // ─── SITE PHOTOS ────────────────────────────────────────
    match /apps/{appId}/site_photos/{docId} {
      allow read: if isMitarbeiter();
      allow create: if isVorarbeiter();
      allow delete: if isAdmin();
    }

    // ─── BAUSTELLEN FOTOS ───────────────────────────────────
    match /apps/{appId}/baustellen_fotos/{docId} {
      allow read: if isMitarbeiter();
      allow create: if isVorarbeiter();
      allow delete: if isAdmin();
    }

    // ─── GLOBAL DENY ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
